{
  model: "Borneo-Industrial-V1",
  compatible: "bst,borneo-lyfi",

  soc: {
    i2c0: {
      compatible: "esp32,i2c",
      reg: [1061158912, 4096, 1061163008, 256],
      interrupts: [12, 1],
      status: "okay",

      bme280: {
        compatible: "bosch,bme280",
        reg: [118],
        oversampling: 4,
      },
    },

    gpio0: {
      compatible: "esp32,gpio",
      reg: [1061171200, 1024],
      gpio_controller: true,
    },
  },
}
